# Development environment variables
APP_ENV=development
SECRET_KEY=change-this-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lcms

# S3 / MinIO
# Leave S3_ENDPOINT_URL empty to use AWS S3.
# Set to MinIO URL for local dev (e.g. http://localhost:9000).
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=lcms
S3_PUBLIC_URL=http://localhost:9000/lcms

# CORS
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:3000","http://127.0.0.1:3000"]

# Question Bank
QUESTION_DRAW_SIZE=5

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=nexedu-lcms-noreply@gmail.com
SMTP_FROM_NAME="NEXEDU LCMS"
SMTP_USE_TLS=true
FRONTEND_URL=http://localhost:5173

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
