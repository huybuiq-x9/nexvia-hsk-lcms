# ============================================================
# Environment Configuration - Test Environment
# For Google Cloud VM deployment
# ============================================================

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test_password_change_me
POSTGRES_DB=lcms_test

# ─── AWS S3 ─────────────────────────────────────────────────
S3_REGION=us-east-1
S3_ACCESS_KEY=your-aws-access-key-id
S3_SECRET_KEY=your-aws-secret-key
S3_BUCKET_NAME=lcms

# ─── App ───────────────────────────────────────────────────
APP_ENV=testing
SECRET_KEY=test-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost

# ─── Frontend URL (used in emails) ──────────────────────────
FRONTEND_URL=http://localhost

# ─── Redis / Celery ─────────────────────────────────────────
# These are set automatically via docker-compose environment; keep here for reference
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── SCORM ──────────────────────────────────────────────────
SCORM_UPLOAD_TMP_DIR=/app/.tmp/scorm-uploads
SCORM_UPLOAD_WORKERS=4

# ─── SMTP (optional for test) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=nexvia-lcms-noreply@gmail.com
SMTP_FROM_NAME="NEXVIA LCMS"
SMTP_USE_TLS=true
