# ============================================================
# Environment Configuration - Test Environment
# For Google Cloud VM deployment
# ============================================================

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test_password_change_me
POSTGRES_DB=lcms_test

S3_REGION=us-east-1
S3_ACCESS_KEY=your-aws-access-key-id
S3_SECRET_KEY=your-aws-secret-key
S3_BUCKET_NAME=lcms

# ─── App ───────────────────────────────────────────────────
APP_ENV=testing
SECRET_KEY=test-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost

# ─── SMTP (optional for test) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=nexvia-lcms-noreply@gmail.com
SMTP_FROM_NAME="NEXVIA LCMS"
SMTP_USE_TLS=true
