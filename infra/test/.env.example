# ============================================================
# Environment Configuration - Test Environment
# For Google Cloud VM deployment
# ============================================================

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test_password_change_me
POSTGRES_DB=lcms_test

# ─── MinIO ─────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_test
S3_BUCKET_NAME=lcms_test

# ─── App ───────────────────────────────────────────────────
APP_ENV=testing
SECRET_KEY=test-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=1

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost

# ─── SMTP (optional for test) ───────────────────────────────
SMTP_HOST=
SMTP_PORT=1025
SMTP_FROM_EMAIL=test@lcms.local
