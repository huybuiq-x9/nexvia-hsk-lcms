# ============================================================
# Environment Configuration - Staging Environment
# ============================================================

# ─── Domain ─────────────────────────────────────────────────
DOMAIN=staging.lcms.example.com

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=staging_password_change_me
POSTGRES_DB=lcms_staging

# ─── MinIO ─────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_staging
S3_BUCKET_NAME=lcms_staging

# ─── App ───────────────────────────────────────────────────
APP_ENV=staging
SECRET_KEY=staging-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=3

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=https://staging.lcms.example.com

# ─── SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=staging@lcms.example.com
