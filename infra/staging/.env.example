# ============================================================
# Environment Configuration - Staging Environment
# ============================================================

# ─── Domain ─────────────────────────────────────────────────
DOMAIN=staging.lcms.example.com

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=staging_password_change_me
POSTGRES_DB=lcms_staging

# ─── MinIO / S3 ─────────────────────────────────────────────
# Leave S3_ENDPOINT_URL empty to use AWS S3.
# Set to MinIO URL for local dev (e.g. http://minio:9000).
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_staging
S3_BUCKET_NAME=lcms
# Via nginx proxy: /minio  |  Direct MinIO (dev only): http://minio:9000/lcms
# For AWS S3: leave empty and use S3_BUCKET_NAME directly
S3_PUBLIC_URL=/minio

# ─── App ───────────────────────────────────────────────────
APP_ENV=staging
SECRET_KEY=staging-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=3

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=https://staging.lcms.example.com

# ─── SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=nexvia-lcms-noreply@gmail.com
SMTP_FROM_NAME="NEXVIA LCMS"
SMTP_USE_TLS=true
