# ============================================================
# Frontend Dockerfile - Development with Vite HMR
# Runs Vite dev server with hot module replacement
# ============================================================
FROM node:20-alpine

WORKDIR /app

# Install pnpm globally
RUN npm install -g pnpm

# Copy package files
COPY front/package*.json ./

# Install dependencies
RUN pnpm install

# Copy source code
COPY front/ .

# Expose port
EXPOSE 5173

# Run Vite dev server
CMD ["pnpm", "dev", "--host", "0.0.0.0"]
