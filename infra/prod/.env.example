# ============================================================
# Environment Configuration - Production Environment
# CRITICAL: Change all passwords and secrets!
# ============================================================

# ─── Domain ─────────────────────────────────────────────────
DOMAIN=lcms.example.com

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD
POSTGRES_DB=lcms_prod

# ─── AWS S3 ─────────────────────────────────────────────────
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY_ID
S3_SECRET_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_BUCKET_NAME=lcms-prod

# ─── App ───────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=CHANGE_TO_VERY_LONG_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=https://lcms.example.com

# ─── Frontend URL (used in emails) ──────────────────────────
FRONTEND_URL=https://lcms.example.com

# ─── Redis / Celery ─────────────────────────────────────────
# These are set automatically via docker-compose environment; keep here for reference
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── SCORM ──────────────────────────────────────────────────
SCORM_UPLOAD_TMP_DIR=/app/.tmp/scorm-uploads
SCORM_UPLOAD_WORKERS=8

# ─── SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=nexvia-lcms-noreply@gmail.com
SMTP_FROM_NAME="NEXVIA LCMS"
SMTP_USE_TLS=true
