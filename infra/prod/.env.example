# ============================================================
# Environment Configuration - Production Environment
# CRITICAL: Change all passwords and secrets!
# ============================================================

# ─── Domain ─────────────────────────────────────────────────
DOMAIN=lcms.example.com

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD
POSTGRES_DB=lcms_prod

# ─── MinIO / S3 ─────────────────────────────────────────────
# Leave S3_ENDPOINT_URL empty to use AWS S3.
# Set to MinIO URL for local dev (e.g. http://minio:9000).
S3_ENDPOINT_URL=
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY_ID
S3_SECRET_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_BUCKET_NAME=lcms
S3_PUBLIC_URL=https://your-cloudfront-url.cloudfront.net

# ─── App ───────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=CHANGE_TO_VERY_LONG_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=https://lcms.example.com

# ─── SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=huybuiq.work@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@lcms.example.com
SMTP_FROM_NAME="HSK LCMS"
