# ============================================================
# Environment Configuration - Development
# Copy to .env and adjust as needed
# ============================================================

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lcms_dev

S3_REGION=us-east-1
S3_ACCESS_KEY=your-aws-access-key-id
S3_SECRET_KEY=your-aws-secret-key
S3_BUCKET_NAME=lcms

# SCORM staging directory must be visible to both backend and celery containers.
SCORM_UPLOAD_TMP_DIR=/app/.tmp/scorm-uploads

# ─── App ───────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=dev-secret-key-change-in-production

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ─── Frontend URL (used in emails) ──────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Redis / Celery ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# ─── SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=nexvia-lcms-noreply@gmail.com
SMTP_FROM_NAME="NEXVIA LCMS"
SMTP_USE_TLS=true
