# ============================================================
# Environment Configuration - Development
# Copy to .env and adjust as needed
# ============================================================

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lcms_dev

# ─── MinIO / S3 ─────────────────────────────────────────────
# Leave S3_ENDPOINT_URL empty to use AWS S3.
# Set to MinIO URL for local dev (e.g. http://minio:9000).
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=lcms
# Direct access via Docker network (browser → localhost:9000 port-mapped by docker)
# No nginx proxy in dev. Keep as http://localhost:9000/lcms
S3_PUBLIC_URL=http://localhost:9000/lcms

# ─── App ───────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=dev-secret-key-change-in-production

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000


# ─── SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=nexvia-lcms-noreply@gmail.com
SMTP_FROM_NAME="NEXVIA LCMS"
SMTP_USE_TLS=true
